---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillCard from "../components/SkillCard.astro";

const skills = [
  {
    title: "JavaScript / TypeScript",
    bullets: [
      "Modern UI development with TypeScript",
      "Modern UI development with ReactJS and Astro",
      "Created UIs used by Insurance Agents working on behalf of Fortune 500 companies",
    ],
  },
  {
    title: "Java",
    bullets: [
      "Backend work with .NET APIs",
      "Internal services and systems integrations",
      "RESTful endpoints and data modeling",
    ],
  },
  {
    title: "AWS",
    bullets: [
      "SNS",
      "SQS",
      "Lambdas",
    ],
  },
  {
    title: "DevOps / Cloud / Automation",
    bullets: [
      "AWS deployment & infrastructure work",
      "CI/CD pipelines & build automation",
      "Automated unit testing & user acceptance testing",
      "Monitoring, logging, and remote debugging",
    ],
  },
];
---

<BaseLayout title="Mitchell Cornwell | Software Engineer">
  <!-- UNDER CONSTRUCTION: Remove the blur wrapper and overlay divs below to restore normal content -->
  <div class="relative">
    <!-- Main content with blur effect - remove "blur-sm pointer-events-none" to undo blur -->
    <!-- <div class="blur-sm pointer-events-none"> -->
      <section class="mb-12">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-cyan">
      Mitchell Cornwell | Software Engineer
    </p>
    <h1
      class="mb-4 text-4xl font-extrabold tracking-tight text-base sm:text-5xl"
    >
      <span class="typewriter-heading">
        Hi, I'm Mitchell.
      </span>
    </h1>

    <!--Maybe extract the below to an About Me section? -->
    <p class="max-w-2xl text-base">
      I have been working professionally as a software engineer since 2017. I
      mostly do backend web development but I have experience creating professional frontend UIs as well.
      <br /><br />
       I enjoy a lot of different hobbies including
      <span class="text-highlight">game design</span> & {" "}
      <span class="text-highlight">game development</span>,{" "}
      <span class="text-highlight">electronics</span>,{" "}
      <span class="text-highlight">freestyle FPV</span>,{" "}
      <span class="text-highlight">music</span> & {" "}
      <span class="text-highlight">music production</span>,{" "}
      <span class="text-highlight">digital art</span>,{" "}
      <span class="text-highlight">animation</span>,{" "}
      <span class="text-highlight">video editing & production</span>,{" "}
      <span class="text-highlight">3D Modeling</span>,{" "}
      <span class="text-highlight">3D Printing</span>, and {" "}
      <span class="text-highlight">playing video games</span>.{" "}
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/projects"
        transition:name="projects-cta"
        class="btn btn-primary"
      >
        View projects
      </a>

      <a
        href="/games"
        class="btn btn-secondary"
      >
        Play games in the browser
      </a>
    </div>
  </section>

  <section class="mt-16">
    <h2 class="mb-6 text-2xl font-bold tracking-tight text-cyan">
      Career Highlights - Under Construction
    </h2>

    <p class="max-w-2xl mb-10 text-sm text-base">
      I've worked on a range of projects professionally — from internal tooling,
      to customer-facing web apps, to backend automation. Here's a quick
      overview of the technologies I’ve used in real-world applications:
    </p>

    <div class="grid gap-8 md:grid-cols-2">
      {
        skills.map((skill) => (
          <SkillCard title={skill.title} bullets={skill.bullets} />
        ))
      }
    </div>
  </section>
  <br />

  <div class="card group">
    <h3 class="card-title group-hover:text-base">Game development</h3>
    <p class="card-text">
      <ul>
        2D game development experience in:
        <li>Godot</li>
        <li>Unity</li>
      </ul>
    </p>
  </div>
  <br />

  <div class="card group">
    <h3 class="card-title group-hover:text-base">Freestyle FPV</h3>
    <p class="card-text">
      I fly freestyle FPV. <br />
       I love tiny whoops <br />
    </p>
  </div>
    </div>
    
    <!-- UNDER CONSTRUCTION: Remove this entire overlay div to restore normal visibility -->
    <!-- <div class="absolute inset-0 flex items-center justify-center bg-black/40">
      <div class="text-center">
        <h2 class="text-4xl font-bold text-base mb-2">🚧 Under Construction</h2>
        <p class="text-lg text-cyan">This page is being updated. Check back soon!</p>
      </div> -->
    </div>
  </div>
</BaseLayout>
