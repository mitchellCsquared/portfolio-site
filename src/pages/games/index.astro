---
import BaseLayout from "../../layouts/BaseLayout.astro";

const games = [
  {
    slug: "placeholder",
    title: "Robot Builder (placeholder)",
    description:
      "Example stub for a Godot HTML5 export. Replace this with a real game later.",
  },
];
---

<BaseLayout title="Games | Mitchell">
  <section class="mb-12">
    <h1 class="mb-2 text-4xl font-extrabold tracking-tight text-base">
      Browser Games
    </h1>
    <p class="max-w-2xl text-base">
      Godot experiments exported to HTML5/WebAssembly and embedded directly in
      the browser. These are work-in-progress prototypes — expect bugs,
      jank, and fun.
    </p>
  </section>

  <section class="grid gap-8 md:grid-cols-2">
    {games.map((game) => (
      <article class="card flex flex-col">
        <h2 class="card-title">
          <a href={`/games/${game.slug}`} class="hover:text-accent transition-colors">
            {game.title}
          </a>
        </h2>
        <p class="card-text mb-3">
          {game.description}
        </p>
        <a
          href={`/games/${game.slug}`}
          class="mt-auto inline-flex w-max items-center gap-1 text-sm font-semibold text-yellow hover:text-accent transition-colors duration-200"
        >
          Play →
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
